# ============================================================
#  Clean URLs for Seven World  (LiteSpeed / Apache via CyberPanel)
#    sevenworld.net            -> index.html  (home)
#    sevenworld.net/about      -> about.html
#    sevenworld.net/services   -> services.html   ... etc.
#    any .html URL  301-redirects to the clean version.
#
#  In CyberPanel:  Websites -> sevenworld.net -> (⋮) htaccess
#  Paste this whole file's contents there and Save.
#  (Or just upload this .htaccess into the site's document root.)
# ============================================================

RewriteEngine On

# 1) /index.html  ->  /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 2) /page.html  ->  /page   (301, SEO-friendly)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3) Serve /page from page.html (internal, no redirect)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
